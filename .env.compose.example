# Copy this file to .env before running docker compose.
# If POSTGRES_PASSWORD contains special URL characters (#, @, :, /, ?),
# either URL-encode it or replace IBKR_DATABASE_URL directly in docker-compose.yml.

POSTGRES_USER=ibkr
POSTGRES_PASSWORD=change_me
# Keep `postgres` when using the built-in compose postgres service.
POSTGRES_HOST=postgres
POSTGRES_DB=ibkr

IBKR_BASE_CURRENCY=USD
IBKR_PORT=4001
IBKR_READONLY=false
IBKR_AUTO_SYNC=true

# Optional: VNC password for IB Gateway desktop
# VNC_PASSWORD=

# Optional: speed up pip install in mainland China
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
